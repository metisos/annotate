# Annotate — environment template
# Copy to .env.local and fill in real values. Never commit real secrets.

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<urlencoded-password>@<host>/annotate_db?retryWrites=true&w=majority
MONGODB_DB=annotate_db

# Firebase (web SDK — public, but still injected at build)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin (server-only). Use ADC locally; service-account JSON in prod.
FIREBASE_ADMIN_PROJECT_ID=
# GOOGLE_APPLICATION_CREDENTIALS=
# FIREBASE_ADMIN_CLIENT_EMAIL=
# FIREBASE_ADMIN_PRIVATE_KEY=

# Vertex AI / Gemini
GCP_PROJECT_ID=
VERTEX_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-pro

# Twelve Labs
TWELVELABS_API_KEY=
TWELVELABS_INDEX_ID=

# E2B
E2B_API_KEY=

# YouTube Data API v3
YOUTUBE_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
